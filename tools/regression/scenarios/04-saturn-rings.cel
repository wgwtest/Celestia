{
    timerate { rate 0 }
    time { jd 2451545.0 }
    labels { clear "planets|minorplanets|stars|constellations" }
    renderflags { set "stars|planets" clear "constellations|orbits|cloudmaps|galaxies" }

    select { object "Saturn" }
    goto { time 0.0 distance 7 up [ 0 1 0 ] upframe "equatorial" }
    wait { duration 1.5 }

    capture { filename "$CAPTURE_FILE$" type "png" }
    exit {}
}
