{
    timerate { rate 0 }
    time { jd 2451545.0 }
    labels { clear "planets|minorplanets|stars|constellations" }
    renderflags { set "stars|galaxies" clear "planets|constellations|orbits|cloudmaps" }

    select { object "Milky Way" }
    goto { time 0.0 distance 180000 }
    wait { duration 1.5 }

    capture { filename "$CAPTURE_FILE$" type "png" }
    exit {}
}
